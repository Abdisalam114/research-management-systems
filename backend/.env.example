PORT=5000
NODE_ENV=development
# Production (Render): set SERVE_FRONTEND=true so Express serves frontend/dist
SERVE_FRONTEND=false
MONGO_URI=mongodb://localhost:27017/rms
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174
REFRESH_COOKIE_NAME=just_rms_refresh

# Bootstrap users (npm run seed) — defined in src/scripts/seedData.js
SEED_DIRECTOR_EMAIL=director@rms.edu
SEED_DIRECTOR_PASSWORD=Director2024!
SEED_COORDINATOR_PASSWORD=Coordinator2024!
SEED_FINANCE_PASSWORD=Finance2024!
SEED_RESEARCHER_PASSWORD=Researcher2024!
